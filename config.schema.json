{
  "pluginAlias": "EufyRobovacMatter",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "username": {
        "title": "Eufy Username",
        "type": "string",
        "required": true
      },
      "password": {
        "title": "Eufy Password",
        "type": "string",
        "required": true
      },
      "disableMatterStatePush": {
        "title": "Disable Matter state push updates (troubleshooting)",
        "type": "boolean",
        "default": false
      },
      "mqttReconnectMaxDelay": {
        "title": "MQTT reconnect max delay (ms)",
        "type": "integer",
        "default": 30000,
        "minimum": 1000
      },
      "defaultMode": {
        "title": "Default cleaning mode",
        "type": "string",
        "default": "AUTO",
        "oneOf": [
          { "title": "Auto", "enum": ["AUTO"] },
          { "title": "Vacuum Only", "enum": ["VACUUM_ONLY"] },
          { "title": "Mop Only", "enum": ["MOP_ONLY"] },
          { "title": "Vacuum + Mop", "enum": ["VACUUM_AND_MOP"] }
        ]
      },
      "defaultSuction": {
        "title": "Default suction level",
        "type": "integer",
        "default": 2,
        "minimum": 1,
        "maximum": 4
      },
      "rooms": {
        "title": "Room selection override",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "title": "Room ID" },
            "name": { "type": "string", "title": "Room Name" }
          },
          "required": ["id", "name"]
        }
      }
    }
  }
}
